# ============================================================
# SMS/Call Forwarder 配置文件
# 短信/来电 Bark 推送转发模块
# ============================================================
#
# 配置文件路径: /data/adb/sms_forwarder/config.conf
# 修改配置后重启手机或重启守护进程即可生效
#

# ======================== Bark 推送地址 ========================
# 支持多个地址，每行一个（不要加引号）
# 格式: https://服务器地址/设备KEY
# 示例:
#   使用 Bark 官方服务器: https://api.day.app/你的KEY
#   使用自建服务器:       https://your-server.com/你的KEY
#
# 注意: 以 # 开头的行会被跳过
BARK_URLS="https://api.day.app/YOUR_KEY_HERE"

# ======================== 轮询间隔 ========================
# 检查新短信/来电的时间间隔（单位：秒）
# 建议值: 5-30，值越小响应越快但耗电越多
POLL_INTERVAL=10

# ======================== 功能开关 ========================
# 是否转发短信 (true/false)
FORWARD_SMS=true
# 是否转发来电 (true/false)
FORWARD_CALL=true

# ======================== 卡槽备注 ========================
# 自定义 SIM 卡名称（可选）
# 留空则自动获取系统中的 SIM 卡名称
# sub_id 通常为 1 和 2，对应两个卡槽
SIM1_NAME=""
SIM2_NAME=""

# ======================== 号码归属地查询 ========================
# 号码归属地查询 API（可选，留空则不查询）
# API 需返回 JSON 格式，包含 province/city 或 prov/city 字段
# 号码会追加到 URL 末尾，例: https://api.example.com/phone?number=13800138000
#
# 推荐 API（自行测试可用性）:
#   https://api.vore.top/api/PhoneSearch?phone=
#   https://api.oioweb.cn/api/common/teladress?mobile=
PHONE_LOCATION_API=""

# ======================== 防洪保护 ========================
# 单次轮询中最大转发条数，超过此数量视为历史消息，全部跳过
# 防止首次启动或状态丢失时转发大量历史记录
MAX_FORWARD_BATCH=10

# ======================== 日志设置 ========================
# 日志级别: 0=关闭 1=仅错误 2=常规信息 3=调试详情
LOG_LEVEL=2
